{
	"name": "octafuse",
	"version": "1.5.0",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/OctaFuse/octafuse-gateway.git"
	},
	"type": "module",
	"workspaces": [
		".",
		"packages/core",
		"packages/proxy",
		"packages/admin"
	],
	"scripts": {
		"postinstall": "patch-package && npm run gen:wrangler",
		"gen:wrangler": "node scripts/deploy/gen-wrangler.mjs",
		"verify:package-versions": "node scripts/ci/verify-package-versions.mjs",
		"ci:changeset-tag-push": "changeset tag && node scripts/ci/push-root-release-tag.mjs",
		"dev:proxy": "npm run dev -w @octafuse/proxy",
		"dev:proxy:node": "dotenv -c -- npm run dev:node -w @octafuse/proxy",
		"dev:admin": "npm run preview -w @octafuse/admin",
		"dev:admin:node": "dotenv -c -- npm run dev:node -w @octafuse/admin",
		"deploy:proxy": "npm run gen:wrangler -- --remote && npm run deploy -w @octafuse/proxy",
		"deploy:admin": "npm run gen:wrangler -- --remote && npm run deploy -w @octafuse/admin",
		"db:migrate": "npm run gen:wrangler && node scripts/deploy/wrangler-d1-cli.mjs migrations apply --local --persist-to .wrangler/state",
		"db:migrate:remote": "npm run gen:wrangler -- --remote && node scripts/deploy/wrangler-d1-cli.mjs migrations apply --remote",
		"db:migrate:pg": "dotenv -c -- tsx packages/core/src/migrate/cli.ts --driver postgres",
		"db:migrate:pg:docker": "node packages/core/dist/migrate/cli.js --driver postgres",
		"db:migrate:mysql": "dotenv -c -- tsx packages/core/src/migrate/cli.ts --driver mysql",
		"db:migrate:mysql:docker": "node packages/core/dist/migrate/cli.js --driver mysql",
		"db:list:pg": "dotenv -c -- tsx scripts/db/diag/list-pg-databases.ts",
		"db:query": "npm run gen:wrangler && node scripts/deploy/wrangler-d1-cli.mjs execute --local --persist-to .wrangler/state --command",
		"db:query:remote": "npm run gen:wrangler -- --remote && node scripts/deploy/wrangler-d1-cli.mjs execute --remote --command",
		"db:export:remote:schema": "tsx scripts/db/d1-remote-export/export-remote-schema.ts",
		"db:export:remote:data": "tsx scripts/db/d1-remote-export/export-remote-data.ts",
		"test:gateway:node-smoke": "dotenv -c -- tsx scripts/smoke/test-node-core-routes.ts",
		"test:gateway:postgres-smoke": "dotenv -c -- tsx scripts/smoke/test-postgres-core-routes.ts",
		"test:gateway:sql-storage-smoke": "dotenv -c -- tsx scripts/smoke/test-storage-concurrent-charge.ts"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.1",
		"@changesets/cli": "^2.29.8",
		"dotenv-cli": "^11.0.0",
		"patch-package": "^8.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.2",
		"wrangler": "^4.68.0"
	}
}
