# gateway-migrate — 一次性 Postgres / MySQL 迁移 Job（不含 proxy / admin 应用代码）
# Build: docker build -f Dockerfile.migrate -t octafuse-migrate:latest .
# Base: Node 22 on Alpine 3.22, pinned digest (see Dockerfile.admin).
ARG NODE_IMAGE=node:22-alpine3.22@sha256:b77017c37f430e4466ff497058948a2f16e8b59779600d53711eeb7b999b0f4e

FROM ${NODE_IMAGE} AS build

WORKDIR /app

RUN apk upgrade --no-cache \
	&& apk add --no-cache ca-certificates

COPY package.json package-lock.json ./
COPY tsconfig.json tsconfig.base.json ./
COPY packages/core/package.json packages/core/
COPY packages/proxy/package.json packages/proxy/
COPY packages/admin/package.json packages/admin/

RUN --mount=type=cache,target=/root/.npm \
	npm ci --ignore-scripts --workspace=@octafuse/core

# esbuild：见 Dockerfile.admin 同段注释
RUN find node_modules -path '*/esbuild/install.js' -exec node {} \;

COPY packages/core ./packages/core

RUN npm run build -w @octafuse/core

FROM ${NODE_IMAGE} AS runner

WORKDIR /app

RUN apk upgrade --no-cache \
	&& apk add --no-cache ca-certificates

COPY --from=build /app/package.json /app/package-lock.json ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/packages/core/package.json ./packages/core/package.json
COPY --from=build /app/packages/core/dist ./packages/core/dist
COPY --from=build /app/packages/core/migrations-postgres ./packages/core/migrations-postgres
COPY --from=build /app/packages/core/migrations-mysql ./packages/core/migrations-mysql

COPY docker/entrypoint.migrate.sh /app/docker/entrypoint.migrate.sh
RUN chmod +x /app/docker/entrypoint.migrate.sh

ENV NODE_ENV=production

ENTRYPOINT ["/app/docker/entrypoint.migrate.sh"]
