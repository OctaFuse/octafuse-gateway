# =============================================================================
# OctaFuse Gateway — 公共演示 / 长期测试实例（octafuse.dev）
# =============================================================================
# 文档入口：同目录 README.md · 运维：docs/ops/deployment-cloudflare.md
#
# 本文件即 dev 实例 canonical 配置（可提交 Git）。生产 soloent / octarouter：
#   复制本文件为 cloudflare-worker/soloent.env 等（gitignore），或只在 Dashboard 配 Build variables。
#
# 本地 CLI：
#   npx dotenv -e ./cloudflare-worker/example.env -- npm run db:migrate:remote
#   npx dotenv -e ./cloudflare-worker/example.env -- npm run deploy:proxy
#   npx dotenv -e ./cloudflare-worker/example.env -- npm run deploy:admin
#
# Git 自动部署：两个 *-dev Worker 的 Build variables 与本文件变量同名同值 → git push
#
# 测试域名（octafuse.dev zone 须在本 Cloudflare 账号；test-* 表明非生产）：
#   Proxy   https://test-api.octafuse.dev
#   Admin   https://test-admin.octafuse.dev
#
# 下游测试用户：
#   GATEWAY_URL=https://test-api.octafuse.dev
#   GATEWAY_MASTER_URL=https://test-admin.octafuse.dev
#   GATEWAY_MASTER_KEY=<D1 system_config.MASTER_KEY>
#
# 首次：npx wrangler d1 create octafuse-gateway-dev → 填入 D1_DATABASE_ID

PROXY_WORKER_NAME=octafuse-gateway-proxy-dev
ADMIN_WORKER_NAME=octafuse-gateway-admin-dev

D1_DATABASE_NAME=octafuse-gateway-dev
D1_DATABASE_ID=e4b8a39b-f369-42e4-bdc2-b603d3f81f5f
# 仅 wrangler d1 migrations 配置名；勿 deploy，无需在 Dashboard 建 Worker
D1_MIGRATIONS_WORKER_NAME=octafuse-d1-migrations-dev

PROXY_CUSTOM_DOMAIN=test-api.octafuse.dev
ADMIN_CUSTOM_DOMAIN=test-admin.octafuse.dev

# =============================================================================
# 其他实例：复制为 cloudflare-worker/<name>.env（勿提交），或只用 Dashboard Build variables
# =============================================================================
#
# soloent 生产：
#   PROXY_WORKER_NAME=octafuse-gateway-proxy
#   ADMIN_WORKER_NAME=octafuse-gateway-admin
#   D1_DATABASE_NAME=octafuse-gateway
#   D1_DATABASE_ID=<wrangler d1 list>
#   （不设 PROXY_CUSTOM_DOMAIN / ADMIN_CUSTOM_DOMAIN）
#
# octarouter 生产（octarouter-gateway fork）：
#   PROXY_WORKER_NAME=octarouter-gateway-proxy
#   ADMIN_WORKER_NAME=octarouter-gateway-admin
#   D1_DATABASE_NAME=octarouter-gateway
#   D1_DATABASE_ID=<wrangler d1 list>
#   PROXY_CUSTOM_DOMAIN=api.octarouter.com
#   ADMIN_CUSTOM_DOMAIN=gateway-admin.octarouter.com
