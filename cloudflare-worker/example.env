# =============================================================================
# OctaFuse Gateway — 公共演示 / 长期测试实例（octafuse.dev）
# =============================================================================
# 本文件即「dev 测试 Worker」的 canonical 配置，可直接用于：
#   - Workers Builds › Build variables（两个 Worker 各配一套，见下方说明）
#   - 本地：填好 D1_DATABASE_ID 后
#     npx dotenv -e ./cloudflare-worker/example.env -- npm run db:migrate:remote
#     npx dotenv -e ./cloudflare-worker/example.env -- npm run deploy:proxy
#     npx dotenv -e ./cloudflare-worker/example.env -- npm run deploy:admin
#
# 域名（须在 Cloudflare 将 octafuse.dev _zone 接入本账号；wrangler deploy 会创建 custom domain）：
#   Proxy（用户推理 / OpenAI 兼容 API）  https://api.octafuse.dev
#   Admin（管理台 + /api/admin/*）       https://gateway-admin.octafuse.dev
#
# 下游 / 文档给测试用户的变量：
#   GATEWAY_URL=https://api.octafuse.dev
#   GATEWAY_MASTER_URL=https://gateway-admin.octafuse.dev
#   GATEWAY_MASTER_KEY=<D1 system_config.MASTER_KEY，部署后从 Admin 或 D1 读取>
#
# 首次部署前创建独立 D1（勿与 soloent / octarouter 生产库混用）：
#   npx wrangler d1 create octafuse-gateway-dev
#   npx wrangler d1 list   # 将 database_id 填入下方 D1_DATABASE_ID

CF_INSTANCE=dev

PROXY_WORKER_NAME=octafuse-gateway-proxy-dev
ADMIN_WORKER_NAME=octafuse-gateway-admin-dev

D1_DATABASE_NAME=octafuse-gateway-dev
D1_DATABASE_ID=e4b8a39b-f369-42e4-bdc2-b603d3f81f5f
# 仅写入 wrangler.d1.jsonc 的 Wrangler 项目名（npm run db:migrate*）；勿 deploy，无需在 Dashboard 建 Worker
D1_MIGRATIONS_WORKER_NAME=octafuse-d1-migrations-dev

PROXY_CUSTOM_DOMAIN=api.octafuse.dev
ADMIN_CUSTOM_DOMAIN=gateway-admin.octafuse.dev

# =============================================================================
# 生产实例参考（复制为 cloudflare-worker/<name>.env，勿与本 dev 实例混用）
# =============================================================================

# --- soloent 生产（octafuse-gateway 仓 Workers Builds）---
# PROXY_WORKER_NAME=octafuse-gateway-proxy
# ADMIN_WORKER_NAME=octafuse-gateway-admin
# D1_DATABASE_NAME=octafuse-gateway
# D1_DATABASE_ID=<wrangler d1 list 确认的真实 UUID>
# D1_MIGRATIONS_WORKER_NAME=octafuse-d1-migrations
# 不设 PROXY_CUSTOM_DOMAIN / ADMIN_CUSTOM_DOMAIN（域由 Dashboard 管理）

# --- octarouter 生产（octarouter-gateway fork）---
# PROXY_WORKER_NAME=octarouter-gateway-proxy
# ADMIN_WORKER_NAME=octarouter-gateway-admin
# D1_DATABASE_NAME=octarouter-gateway
# D1_DATABASE_ID=0236317c-5b3d-433b-9d5a-a2bad1c527f1
# D1_MIGRATIONS_WORKER_NAME=octarouter-d1-migrations
# PROXY_CUSTOM_DOMAIN=api.octarouter.com
# ADMIN_CUSTOM_DOMAIN=gateway-admin.octarouter.com
