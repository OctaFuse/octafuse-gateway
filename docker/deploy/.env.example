# Copy to docker/deploy/.env.local (or .env.gateway) — do not commit real secrets.
# See docker/examples/env.*.example for full variable lists and comments.

# 本仓 CI 默认 GHCR 镜像（OctaFuse 组织）；fork 后请改为你的 ghcr.io/<owner>/<repo>-{proxy,admin,migrate}:<tag>
# GATEWAY_PROXY_IMAGE=ghcr.io/octafuse/octafuse-gateway-proxy:latest
# GATEWAY_ADMIN_IMAGE=ghcr.io/octafuse/octafuse-gateway-admin:latest
# GATEWAY_MIGRATE_IMAGE=ghcr.io/octafuse/octafuse-gateway-migrate:latest

# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?options=-c%20timezone%3DUTC

# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=replace-me

# Optional host port mapping (container ports stay 8787 / 8789)
# GATEWAY_PROXY_PORT=18787
# GATEWAY_ADMIN_PORT=18789
