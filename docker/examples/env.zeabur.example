# Zeabur 部署环境变量模板（勿提交真实密钥）
# 完整说明见 docs/operators/deployment/zeabur.md
#
# 推荐：在 proxy 或 admin 上设 AUTO_MIGRATE=1，启动时自动迁移，无需单独 migrate Service。
# 备选：migrate 镜像为一次性 Job，不要在 Zeabur 上作为常驻 Service 长期运行。
# 推荐：发版前在本地/CI 执行 scripts/deploy/zeabur-migrate-once.sh，再部署 proxy/admin。

# ── gateway-proxy Service ─────────────────────────────────────────────
# ZBPACK_DOCKERFILE_PATH=Dockerfile.proxy
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/octafuse?options=-c%20timezone%3DUTC
# PORT=8787
# AUTO_MIGRATE=1

# ── gateway-admin Service ─────────────────────────────────────────────
# ZBPACK_DOCKERFILE_PATH=Dockerfile.admin
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/octafuse?options=-c%20timezone%3DUTC
# PORT=8789
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=replace-me
# AUTO_MIGRATE=1

# ── migrate（仅一次性；或 PREBUILT 镜像跑完后 Suspend）────────────────
# ZBPACK_DOCKERFILE_PATH=Dockerfile.migrate
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/octafuse?options=-c%20timezone%3DUTC
#
# 若使用 GHCR 预构建镜像（PREBUILT，非 Git 构建）：
# GATEWAY_MIGRATE_IMAGE=ghcr.io/octafuse/octafuse-gateway-migrate:latest
# GATEWAY_PROXY_IMAGE=ghcr.io/octafuse/octafuse-gateway-proxy:latest
# GATEWAY_ADMIN_IMAGE=ghcr.io/octafuse/octafuse-gateway-admin:latest
