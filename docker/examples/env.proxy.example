# Copy to .env.gateway for gateway.proxy.yml

# GATEWAY_PROXY_IMAGE=ghcr.io/example-org/octafuse-proxy:latest
# 国内阿里云 ACR：`docker login registry.cn-shanghai.aliyuncs.com`（RAM 访问凭证）。拉取慢或不可达 ghcr 时可改为例如（固定 tag，与发版一致；地域/命名空间以你的实例为准）：
GATEWAY_PROXY_IMAGE=registry.cn-shanghai.aliyuncs.com/example-org/octafuse-proxy:latest
# `--profile migrate` 时需要：
# GATEWAY_MIGRATE_IMAGE=registry.cn-shanghai.aliyuncs.com/example-org/octafuse-migrate:latest

# 宿主机映射端口（默认 18787）；容器内固定 8787
GATEWAY_PROXY_PORT=18787

# 外置 Postgres（云 RDS / 自建实例等）；MySQL 时改为 mysql:// 并设 DATABASE_DRIVER=mysql
DATABASE_URL=postgres://gateway_user:change-me@db.example.com:5432/octafuse
DATABASE_DRIVER=postgres

# 迁移由 migrate 镜像负责：docker compose --profile migrate run --rm migrate
