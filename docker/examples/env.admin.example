# Copy to .env.gateway for gateway.admin.yml

GATEWAY_ADMIN_IMAGE=ghcr.io/example-org/octafuse-admin:latest

# 仅用于 `docker compose --profile migrate run --rm migrate`：用 **migrate 镜像**跑一次性 DB 迁移（不要求部署 gateway-proxy 容器）。
# GATEWAY_MIGRATE_IMAGE=ghcr.io/example-org/octafuse-migrate:latest
# 国内阿里云 ACR：`docker login registry.cn-shanghai.aliyuncs.com`。可将 `GATEWAY_ADMIN_IMAGE` / `GATEWAY_MIGRATE_IMAGE` 改为例如（固定 tag；地域/命名空间以你的实例为准，例如命名空间 `example-org`）：
GATEWAY_MIGRATE_IMAGE=registry.cn-shanghai.aliyuncs.com/example-org/octafuse-migrate:latest

# 宿主机映射端口（默认 18789）；容器内固定 8789
GATEWAY_ADMIN_PORT=18789

# 与 proxy 使用同一逻辑库（首次建库请先执行上行的 migrate）；MySQL 时改为 mysql:// 并设 DATABASE_DRIVER=mysql
DATABASE_URL=postgres://gateway_user:change-me@db.example.com:5432/octafuse
DATABASE_DRIVER=postgres

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
