# Copy to .env.gateway for gateway.admin.yml
#
# CI 推送命名见 .github/workflows/octafuse-docker-images.yml（本组织默认如下）。
GATEWAY_ADMIN_IMAGE=ghcr.io/octafuse/octafuse-gateway-admin:latest
# 任意私有 OCI registry（如自建 Harbor）：按需 mirror / retag，例如：
# GATEWAY_ADMIN_IMAGE=registry.example.com/example-org/octafuse-gateway-admin:latest

# 仅用于 `docker compose --profile migrate run --rm migrate`：用 **migrate 镜像**跑一次性 DB 迁移（不要求部署 gateway-proxy 容器）。
GATEWAY_MIGRATE_IMAGE=ghcr.io/octafuse/octafuse-gateway-migrate:latest
# GATEWAY_MIGRATE_IMAGE=registry.example.com/example-org/octafuse-gateway-migrate:latest

# 宿主机映射端口（默认 18789）；容器内固定 8789
GATEWAY_ADMIN_PORT=18789

# 与 proxy 使用同一逻辑库（首次建库请先执行上行的 migrate）；MySQL 时改为 mysql:// 并设 DATABASE_DRIVER=mysql
DATABASE_URL=postgres://gateway_user:change-me@db.example.com:5432/octafuse
DATABASE_DRIVER=postgres

# 可选：容器启动前自动迁移。默认关闭；通常只需在 proxy 或 admin 之一开启。
# AUTO_MIGRATE=1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
