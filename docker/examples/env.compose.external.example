# Copy to .env.gateway，与 gateway.compose.yml 同时使用（外置 Postgres，同时起 proxy + admin）
# docker compose --env-file .env.gateway -f gateway.compose.yml up -d
# migrate：docker compose --env-file .env.gateway -f gateway.compose.yml --profile migrate run --rm migrate
# CI 推送名见 .github/workflows/octafuse-docker-images.yml

# GATEWAY_PROXY_IMAGE=ghcr.io/example-org/octafuse-proxy:latest
# GATEWAY_ADMIN_IMAGE=ghcr.io/example-org/octafuse-admin:latest
# GATEWAY_MIGRATE_IMAGE=ghcr.io/example-org/octafuse-migrate:latest
# 任意私有 OCI registry（如阿里云 ACR、自建 Harbor 等）：`docker login registry.example.com`。
# 可将上三行改为类似下面的形态（固定 tag；registry/namespace 以你的实例为准）：
GATEWAY_PROXY_IMAGE=registry.example.com/example-org/octafuse-proxy:latest
GATEWAY_ADMIN_IMAGE=registry.example.com/example-org/octafuse-admin:latest
GATEWAY_MIGRATE_IMAGE=registry.example.com/example-org/octafuse-migrate:latest

# 宿主机映射（默认 18787 / 18789）；容器内 proxy 固定 8787、admin 固定 8789
GATEWAY_PROXY_PORT=18787
GATEWAY_ADMIN_PORT=18789

DATABASE_URL=postgres://gateway_user:change-me@db.example.com:5432/octafuse
DATABASE_DRIVER=postgres

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
