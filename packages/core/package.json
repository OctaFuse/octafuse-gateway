{
	"name": "@octafuse/core",
	"version": "1.3.0",
	"private": true,
	"type": "module",
	"bin": {
		"octafuse-migrate": "./dist/migrate/cli.js"
	},
	"scripts": {
		"prebuild": "node -e \"try{require('fs').rmSync('dist',{recursive:true,force:true})}catch(e){}\"",
		"build": "npm run build:migrate && npm run build:node-index",
		"build:migrate": "tsc -p tsconfig.build.migrate.json",
		"build:node-index": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --log-level=warning"
	},
	"files": [
		"dist",
		"migrations-d1",
		"migrations-postgres",
		"migrations-mysql",
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"node": "./dist/index.js",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./db/pricing-profile": "./src/db/pricing-profile.ts",
		"./db/model-modalities": "./src/db/model-modalities.ts",
		"./db/request-log-status-filter": "./src/db/request-log-status-filter.ts",
		"./db/user-audit-catalog": "./src/db/user-audit-catalog.ts",
		"./db/user-budget-audit-params": "./src/db/user-budget-audit-params.ts",
		"./db/user-budget-audit-mapper": "./src/db/user-budget-audit-mapper.ts",
		"./db/user-audit-log-derived": "./src/db/user-audit-log-derived.ts",
		"./db/user-audit-metadata": "./src/db/user-audit-metadata.ts",
		"./db/user-audit-snapshot": "./src/db/user-audit-snapshot.ts",
		"./db/users-list-sort": "./src/db/users-list-sort.ts",
		"./db/api-keys-list-sort": "./src/db/api-keys-list-sort.ts",
		"./lib/business-timezone": "./src/lib/business-timezone.ts",
		"./lib/billing-currency": "./src/lib/billing-currency.ts",
		"./lib/alert-webhook-system-config": "./src/lib/alert-webhook-system-config.ts",
		"./lib/money-precision": "./src/lib/money-precision.ts",
		"./lib/string-utils": "./src/lib/string-utils.ts",
		"./lib/time-format": "./src/lib/time-format.ts",
		"./services/key-service": "./src/services/key-service.ts",
		"./services/user-service": "./src/services/user-service.ts",
		"./storage/drizzle/client-d1": "./src/storage/drizzle/client-d1.ts",
		"./storage/repositories-d1": "./src/storage/repositories-d1.ts",
		"./storage/runtime-database-config": "./src/storage/runtime-database-config.ts",
		"./storage/context": "./src/storage/context.ts",
		"./upstream-protocol": "./src/upstream-protocol.ts"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"mysql2": "^3.22.0",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250427.0",
		"@types/node": "^25.5.0",
		"esbuild": "^0.27.3",
		"typescript": "^5.7.2"
	}
}
